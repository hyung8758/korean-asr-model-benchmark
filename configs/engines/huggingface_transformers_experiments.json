{
  "engine": "huggingface_transformers",
  "manifest_path": "benchmark_data/huggingface_transformers_combined_manifest.jsonl",
  "manifest_paths": [
    "benchmark_data/manifest.jsonl"
  ],
  "result_root": "results",
  "language": "ko",
  "device": "cuda:0",
  "launcher": {
    "gpu_ids": [0, 1, 2, 3, 4, 5],
    "evaluate_after_decode": true
  },
  "decode_defaults": {
    "task": "transcribe",
    "beam_size": 1,
    "batch_size": 1,
    "chunk_length_s": 30,
    "return_timestamps": false
  },
  "experiments": [
    {
      "name": "crisperwhisper_beam1_float16",
      "model": "nyrahealth/CrisperWhisper",
      "beam_size": 1,
      "precision": "float16",
      "return_timestamps": false
    },
    {
      "name": "ghost613_whisper_large_v3_turbo_korean_beam1_float16",
      "model": "ghost613/whisper-large-v3-turbo-korean",
      "beam_size": 1,
      "precision": "float16",
      "return_timestamps": false
    }
  ]
}
