{
  "engine": "hf_asr",
  "manifest_path": "benchmark_data/hf_asr_combined_manifest.jsonl",
  "manifest_paths": [
    "benchmark_data/manifest.jsonl"
  ],
  "result_root": "results",
  "language": "ko",
  "device": "cuda:0",
  "launcher": {
    "gpu_ids": [0, 1, 2, 3, 4, 5],
    "evaluate_after_decode": true
  },
  "decode_defaults": {
    "task": "transcribe",
    "beam_size": 1,
    "batch_size": 1,
    "chunk_length_s": 30,
    "return_timestamps": false,
    "qwen_language": "Korean",
    "max_inference_batch_size": 1,
    "max_new_tokens": 256
  },
  "experiments": [
    {
      "name": "crisperwhisper_beam1_float16",
      "model": "nyrahealth/CrisperWhisper",
      "runner": "transformers_whisper",
      "beam_size": 1,
      "precision": "float16",
      "return_timestamps": false
    },
    {
      "name": "ghost613_whisper_large_v3_turbo_korean_beam1_float16",
      "model": "ghost613/whisper-large-v3-turbo-korean",
      "runner": "transformers_whisper",
      "beam_size": 1,
      "precision": "float16",
      "return_timestamps": false
    },
    {
      "name": "qwen3_asr_1_7b_bfloat16",
      "model": "Qwen/Qwen3-ASR-1.7B",
      "runner": "qwen_asr",
      "beam_size": 1,
      "precision": "bfloat16",
      "qwen_language": "Korean",
      "return_timestamps": false,
      "max_new_tokens": 256
    }
  ]
}
